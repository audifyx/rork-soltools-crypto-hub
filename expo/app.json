{
  "expo": {
    "name": "SolTools",
    "slug": "ct333efmdotyxkemvlyk6",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#030708"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.ct333efmdotyxkemvlyk6",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#030708"
      },
      "package": "app.rork.ct333efmdotyxkemvlyk6"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow SolTools to protect your trading wallet keys with Face ID."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SolTools to access your photos and videos so you can upload profile media, posts, and reels."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
