{
  "expo": {
    "name": "Social Alpha Cockpit",
    "slug": "soltools-agoq9mmx54xvahqna2fmv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#030708"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.ct333efmdotyxkemvlyk6",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Social Alpha Cockpit needs the microphone to let you speak in live Spaces."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#030708"
      },
      "package": "app.rork.ct333efmdotyxkemvlyk6",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow Social Alpha Cockpit to protect your trading wallet keys with Face ID."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Social Alpha Cockpit to access your photos and videos so you can upload profile media, posts, and reels."
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "8e264cab-b6f0-42e8-a85f-ef2b1f761c5c"
      }
    }
  }
}
